<Window x:Class="Appreciate.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Appreciate — Settings"
        Width="440" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✨ Appreciate" FontSize="24" FontWeight="Bold"
                   Foreground="White" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" Text="Enjoy and appreciate being alive"
                   Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="2" Text="Reminder Text (one per line)"
                   Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
        <ComboBox Grid.Row="3" x:Name="PackComboBox"
                  Background="#2D2D2D" Foreground="White"
                  FontSize="13" Margin="0,0,0,8"
                  SelectionChanged="OnPackChanged"/>
        <TextBox Grid.Row="4" x:Name="ReminderTextBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 Height="80" Background="#2D2D2D" Foreground="White"
                 BorderBrush="#444" Padding="8" FontSize="13" Margin="0,0,0,16"
                 TextChanged="OnReminderTextChanged"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,8">
            <CheckBox x:Name="EnabledCheckBox" Content="Enabled"
                      Foreground="White" FontSize="14" VerticalContentAlignment="Center"
                      Margin="0,0,24,0"/>
            <CheckBox x:Name="LaunchAtLoginCheckBox" Content="Launch at Login"
                      Foreground="White" FontSize="14" VerticalContentAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="6" Margin="0,8,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Min Interval" Foreground="White" FontSize="13" FontWeight="Bold"/>
                <Slider x:Name="MinIntervalSlider" Minimum="0.5" Maximum="60"
                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                        ValueChanged="OnSliderChanged"/>
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="MinIntervalLabel"
                       Foreground="White" FontSize="13" VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"/>
        </Grid>

        <Grid Grid.Row="7" Margin="0,8,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Max Interval" Foreground="White" FontSize="13" FontWeight="Bold"/>
                <Slider x:Name="MaxIntervalSlider" Minimum="1" Maximum="120"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="OnSliderChanged"/>
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="MaxIntervalLabel"
                       Foreground="White" FontSize="13" VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"/>
        </Grid>

        <Grid Grid.Row="8" Margin="0,8,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Display Duration" Foreground="White" FontSize="13" FontWeight="Bold"/>
                <Slider x:Name="DurationSlider" Minimum="2" Maximum="10"
                        TickFrequency="0.5" IsSnapToTickEnabled="True"
                        ValueChanged="OnSliderChanged"/>
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="DurationLabel"
                       Foreground="White" FontSize="13" VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"/>
        </Grid>

        <Button Grid.Row="10" Content="✨ Show Now" FontSize="14"
                x:Name="ShowNowButton" Click="OnShowNow"
                Background="#FFB74D" Foreground="Black"
                Padding="12,8" Cursor="Hand"/>
    </Grid>
</Window>
